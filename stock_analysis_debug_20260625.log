ring', 'description': "Stock code, e.g., '600519'"}}, 'required': ['stock_code']}}}, {'type': 'function', 'function': {'name': 'get_report_context', 'description': 'Reuse a previous homepage analysis record by record_id. Returns a compact context_snapshot and DB-cached daily_history. Use this first for follow-up chats to avoid redundant fetches.', 'parameters': {'type': 'object', 'properties': {'record_id': {'type': 'integer', 'description': 'Analysis history record id from homepage report (recordId in URL).'}, 'days': {'type': 'integer', 'description': 'How many trading days of OHLCV to include from DB (default 60).'}}, 'required': ['record_id']}}}, {'type': 'function', 'function': {'name': 'get_stock_info', 'description': 'Get stock fundamental information: valuation, growth, earnings, institution flow, stock sector membership (belong_boards; boards is compatibility alias) and sector rankings. Returns a compact fundamental_context to reduce token usage.', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "A-share stock code, e.g., '600519'"}}, 'required': ['stock_code']}}}, {'type': 'function', 'function': {'name': 'get_portfolio_snapshot', 'description': 'Get portfolio snapshot summary and optional risk blocks. Default returns compact summary for lower token usage; set include_positions=true to include full position details.', 'parameters': {'type': 'object', 'properties': {'account_id': {'type': 'integer', 'description': 'Optional account id; omit to use all active accounts.'}, 'cost_method': {'type': 'string', 'description': 'Cost method: fifo or avg (default: fifo).', 'enum': ['fifo', 'avg']}, 'include_positions': {'type': 'boolean', 'description': 'Whether to include full positions in snapshot output (default: false).'}, 'include_risk': {'type': 'boolean', 'description': 'Whether to include risk summary block (default: true).'}, 'as_of': {'type': 'string', 'description': 'Optional snapshot date in YYYY-MM-DD format (default: today).'}}}}}, {'type': 'function', 'function': {'name': 'get_capital_flow', 'description': "Get main-force (主力) capital flow data for an A-share stock. Returns today's net inflow, 5-day and 10-day cumulative inflows, and top sector-level capital flow rankings. Only supported for A-share individual stocks (not ETFs, indices, HK, or US stocks).", 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "A-share stock code, e.g., '600519'"}}, 'required': ['stock_code']}}}, {'type': 'function', 'function': {'name': 'analyze_trend', 'description': 'Run comprehensive technical trend analysis on a stock. Fetches historical data from database or data source. Returns MA alignment, bias rates, MACD status, RSI levels, volume analysis, support/resistance levels, and a buy/sell signal with a score (0-100).', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "Stock code to analyze, e.g., '600519'"}}, 'required': ['stock_code']}}}, {'type': 'function', 'function': {'name': 'calculate_ma', 'description': 'Calculate moving averages (MA5/10/20/30/60/120/250 or custom periods) for a stock. Returns each MA value, price bias %, and whether price is above each MA. Also returns overall MA alignment (多头/空头/混合).', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "Stock code, e.g., '600519'"}, 'periods': {'type': 'string', 'description': "Comma-separated MA periods to calculate (default: '5,10,20,30,60,120,250'). E.g., '5,10,20,60'"}, 'days': {'type': 'integer', 'description': 'Number of trading days to fetch history for (default: 120)'}}, 'required': ['stock_code']}}}, {'type': 'function', 'function': {'name': 'get_volume_analysis', 'description': 'Analyse volume-price relationship for a stock. Returns volume ratios, average volume on up vs down days, volume trend (expanding/shrinking), and pattern interpretation (量价配合/背离). Useful for confirming trend strength and detecting distribution or accumulation phases.', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "Stock code, e.g., '600519'"}, 'days': {'type': 'integer', 'description': 'Number of recent trading days to analyse (default: 30)'}}, 'required': ['stock_code']}}}, {'type': 'function', 'function': {'name': 'analyze_pattern', 'description': 'Detect candlestick and chart patterns in recent price history. Identifies: Doji, Hammer, Shooting Star, Morning/Evening Star, Engulfing, Double Bottom, upward breakout, box oscillation, and more. Returns pattern list with type (bullish/bearish/reversal) and strength.', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "Stock code, e.g., '600519'"}, 'days': {'type': 'integer', 'description': 'Number of recent trading days to scan (default: 60)'}}, 'required': ['stock_code']}}}, {'type': 'function', 'function': {'name': 'search_stock_news', 'description': 'Search for the latest news articles about a specific stock. Requires both stock_code and stock_name for accurate search. Returns news titles, snippets, sources, and URLs.', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "Stock code, e.g., '600519'"}, 'stock_name': {'type': 'string', 'description': "Stock name in Chinese, e.g., '贵州茅台'"}}, 'required': ['stock_code', 'stock_name']}}}, {'type': 'function', 'function': {'name': 'search_comprehensive_intel', 'description': 'Multi-dimensional intelligence search: latest news, market analysis, risk checking, earnings outlook, and industry trends for a stock. Returns a formatted report and structured results.', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "Stock code, e.g., '600519'"}, 'stock_name': {'type': 'string', 'description': "Stock name in Chinese, e.g., '贵州茅台'"}}, 'required': ['stock_code', 'stock_name']}}}, {'type': 'functio