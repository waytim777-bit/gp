e": 0.56, "reasoning": "当前MA5<MA10<MA20形成空头排列，且MACD DIF下穿零轴，趋势转弱，追多性价比不高。虽然RSI偏弱且出现“上吊线”类反转信号，但量能与结构尚未扭转，倾向等待在支撑位企稳后的确认信号再做操作。", "key_levels": {"support": 15.8, "resistance": 17.6, "stop_loss": 15.3}, "trend_score": 33, "ma_alignment": "bearish", "volume_status": "normal", "pattern": "上吊线 (Hanging Man)"}'}], caching=False, client=None, temperature=0.7, timeout=542.1841096878052, tools=[{'type': 'function', 'function': {'name': 'get_daily_history', 'description': 'Get daily OHLCV (open, high, low, close, volume) historical data with MA5/MA10/MA20 indicators. Returns the last N trading days.', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "Stock code, e.g., '600519' (A-share), 'AAPL' (US)"}, 'days': {'type': 'integer', 'description': 'Number of trading days to fetch (default: 60)'}}, 'required': ['stock_code']}}}, {'type': 'function', 'function': {'name': 'analyze_trend', 'description': 'Run comprehensive technical trend analysis on a stock. Fetches historical data from database or data source. Returns MA alignment, bias rates, MACD status, RSI levels, volume analysis, support/resistance levels, and a buy/sell signal with a score (0-100).', 'parameters': {'type': 'object', 'properties': {'stock_code': {'type': 'string', 'description': "Stock code to analyze, e.g., '600519'"}}, 'required': ['stock_code']}}}], litellm_trace_id='fca00de5-2cba-41cf-84de-8acc9df64ffb', metadata={'model_group': 'openai/gpt-5.4-nano', 'model_group_alias': None, 'model_group_size': 1, 'attempted_retries': 0, 'max_retries': 2, 'deployment': 'openai/gpt-5.4-nano', 'model_info': {'id': '335b8017ae0cd97bacd039853f96491ce32a8ffa5a5576ebf29c3c4755f67131', 'db_model': False}, 'api_base': 'https://api.cometapi.com/v1', 'deployment_model_name': 'openai/gpt-5.4-nano', 'caching_groups': None}, model_info={'id': '335b8017ae0cd97bacd039853f96491ce32a8ffa5a5576ebf29c3c4755f67131', 'db_model': False}, max_retries=0)[0m
